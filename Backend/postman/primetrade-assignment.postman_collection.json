{
  "info": {
    "_postman_id": "7c9d3f7c-2ff1-4c89-9ef7-primetrade-assignment",
    "name": "Primetrade Assignment API",
    "description": "Postman collection for the JWT-based auth and task management APIs. Set the `baseUrl` variable and use the `accessToken` variable in the Authorization header as a Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:7000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "taskId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a user account and returns a bearer access token."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"statusCode\": 201,\n  \"data\": {\n    \"user\": {\n      \"_id\": \"661111111111111111111111\",\n      \"name\": \"Jane Doe\",\n      \"email\": \"jane@example.com\",\n      \"role\": \"user\",\n      \"createdAt\": \"2026-03-29T10:00:00.000Z\",\n      \"updatedAt\": \"2026-03-29T10:00:00.000Z\"\n    },\n    \"accessToken\": \"<jwt>\",\n    \"tokenType\": \"Bearer\"\n  },\n  \"message\": \"User registered successfully\",\n  \"success\": true\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"Secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs a user in and returns a bearer access token."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"data\": {\n    \"user\": {\n      \"_id\": \"661111111111111111111111\",\n      \"name\": \"Jane Doe\",\n      \"email\": \"jane@example.com\",\n      \"role\": \"user\",\n      \"createdAt\": \"2026-03-29T10:00:00.000Z\",\n      \"updatedAt\": \"2026-03-29T10:00:00.000Z\"\n    },\n    \"accessToken\": \"<jwt>\",\n    \"tokenType\": \"Bearer\"\n  },\n  \"message\": \"Logged in successfully\",\n  \"success\": true\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Finish backend assignment\",\n  \"description\": \"Implement auth, RBAC, validation, and CRUD APIs.\",\n  \"status\": \"pending\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ]
            },
            "description": "Creates a task for the authenticated user. Send the JWT in the Authorization header."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"statusCode\": 201,\n  \"data\": {\n    \"_id\": \"662222222222222222222222\",\n    \"title\": \"Finish backend assignment\",\n    \"description\": \"Implement auth, RBAC, validation, and CRUD APIs.\",\n    \"status\": \"pending\",\n    \"user\": {\n      \"_id\": \"661111111111111111111111\",\n      \"name\": \"Jane Doe\",\n      \"email\": \"jane@example.com\",\n      \"role\": \"user\"\n    },\n    \"createdAt\": \"2026-03-29T10:10:00.000Z\",\n    \"updatedAt\": \"2026-03-29T10:10:00.000Z\"\n  },\n  \"message\": \"Task created successfully\",\n  \"success\": true\n}"
            }
          ]
        },
        {
          "name": "Get Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ]
            },
            "description": "Returns the current user's tasks. Admin users receive all tasks."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"data\": [\n    {\n      \"_id\": \"662222222222222222222222\",\n      \"title\": \"Finish backend assignment\",\n      \"description\": \"Implement auth, RBAC, validation, and CRUD APIs.\",\n      \"status\": \"pending\",\n      \"user\": {\n        \"_id\": \"661111111111111111111111\",\n        \"name\": \"Jane Doe\",\n        \"email\": \"jane@example.com\",\n        \"role\": \"user\"\n      },\n      \"createdAt\": \"2026-03-29T10:10:00.000Z\",\n      \"updatedAt\": \"2026-03-29T10:10:00.000Z\"\n    }\n  ],\n  \"message\": \"Tasks fetched successfully\",\n  \"success\": true\n}"
            }
          ]
        },
        {
          "name": "Admin - Get All Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/admin/all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "admin",
                "all"
              ]
            },
            "description": "Admin-only route that returns every task in the system."
          }
        },
        {
          "name": "Get Task By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            },
            "description": "Fetches a single task if the authenticated user owns it or is an admin."
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\",\n  \"description\": \"Assignment delivered.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            },
            "description": "Updates an owned task or any task if the caller is an admin."
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            },
            "description": "Deletes an owned task or any task if the caller is an admin."
          }
        }
      ]
    }
  ]
}
